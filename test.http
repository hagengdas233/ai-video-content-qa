@host = http://localhost:9090
@user1Username = <user-1-username>
@user1Password = <user-1-password>
@user2Username = <user-2-username>
@user2Password = <user-2-password>
@user1MediaId = <media-id-owned-by-user-1>
@user2SameContentMediaId = <same-content-media-id-owned-by-user-2>
@expectedContentHash = <lowercase-32-character-md5>

### 1. User 1 login and capture the signed JWT
# @name user1Login
POST {{host}}/user/login
Content-Type: application/json

{
  "username": "{{user1Username}}",
  "password": "{{user1Password}}"
}

> {%
client.test("User 1 login returned a JWT", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.code === 200, "Expected business code 200");
  client.assert(response.body.token, "Expected token in login response");
  client.assert(response.body.token.split(".").length === 3, "Expected compact JWT format");
});
client.global.set("user1Token", response.body.token);
const index = Math.floor(response.body.token.length / 2);
const current = response.body.token.charAt(index);
const replacement = current === "a" ? "b" : "a";
client.global.set(
  "tamperedUser1Token",
  response.body.token.substring(0, index) + replacement + response.body.token.substring(index + 1)
);
%}

### User 2 login and capture its own signed JWT
# @name user2Login
POST {{host}}/user/login
Content-Type: application/json

{
  "username": "{{user2Username}}",
  "password": "{{user2Password}}"
}

> {%
client.test("User 2 login returned a JWT", function () {
  client.assert(response.status === 200, "Expected HTTP 200");
  client.assert(response.body.code === 200, "Expected business code 200");
  client.assert(response.body.token.split(".").length === 3, "Expected compact JWT format");
});
client.global.set("user2Token", response.body.token);
%}

### 2. User 1 analyzes a video owned by User 1
# @name firstAnalysis
POST {{host}}/media/analyze/{{user1MediaId}}
Authorization: Bearer {{user1Token}}
Content-Type: application/json

{}

> {%
client.test("First analysis is accepted", function () {
  client.assert(response.status === 202, "Expected HTTP 202");
  client.assert(response.body.status === "SUBMITTED", "Expected SUBMITTED");
});
%}

### 3. Missing token must return HTTP 401
POST {{host}}/media/analyze/{{user1MediaId}}
Content-Type: application/json

{}

> {%
client.test("Missing token is rejected", function () {
  client.assert(response.status === 401, "Expected HTTP 401");
});
%}

### 4. The old forgeable demo token must return HTTP 401
POST {{host}}/media/analyze/{{user1MediaId}}
Authorization: Bearer user_1
Content-Type: application/json

{}

> {%
client.test("Forged user_1 token is rejected", function () {
  client.assert(response.status === 401, "Expected HTTP 401");
});
%}

### 5. A one-character JWT modification must return HTTP 401
POST {{host}}/media/analyze/{{user1MediaId}}
Authorization: Bearer {{tamperedUser1Token}}
Content-Type: application/json

{}

> {%
client.test("Tampered JWT is rejected", function () {
  client.assert(response.status === 401, "Expected HTTP 401");
});
%}

### 6a. Expired JWT preparation
# Restart the backend temporarily with JWT_EXPIRATION=1, then run this login request.
# @name expiringLogin
POST {{host}}/user/login
Content-Type: application/json

{
  "username": "{{user1Username}}",
  "password": "{{user1Password}}"
}

> {%
client.global.set("expiredToken", response.body.token);
%}

### 6b. Wait briefly, then the expired JWT must return HTTP 401
# Restore JWT_EXPIRATION to 86400000 after this test.
POST {{host}}/media/analyze/{{user1MediaId}}
Authorization: Bearer {{expiredToken}}
Content-Type: application/json

{}

> {%
client.test("Expired JWT is rejected", function () {
  client.assert(response.status === 401, "Expected HTTP 401");
});
%}

### 7. User 2 cannot analyze User 1's video
POST {{host}}/media/analyze/{{user1MediaId}}
Authorization: Bearer {{user2Token}}
Content-Type: application/json

{}

> {%
client.test("Cross-user access is rejected", function () {
  client.assert(response.status === 403, "Expected HTTP 403");
});
%}

### 8. Repeat immediately after request 2; no second MQ task should be sent
POST {{host}}/media/analyze/{{user1MediaId}}
Authorization: Bearer {{user1Token}}
Content-Type: application/json

{}

> {%
client.test("Duplicate analysis reports RUNNING", function () {
  client.assert(response.status === 202, "Expected HTTP 202");
  client.assert(response.body.status === "RUNNING", "Expected RUNNING");
  client.assert(response.body.message === "Analysis task is already running", "Expected duplicate message");
});
%}

### 9. Redis miss must fall back to media_files.content_hash and repopulate the cache
# Preconditions:
# 1. media_files.content_hash for user1MediaId equals expectedContentHash.
# 2. DEL media:md5:{user1MediaId} and any non-running analysis key.
POST {{host}}/media/analyze/{{user1MediaId}}
Authorization: Bearer {{user1Token}}
Content-Type: application/json

{}

> {%
client.test("MySQL contentHash is used when Redis cache is empty", function () {
  client.assert(response.status === 202, "Expected HTTP 202");
  client.assert(response.body.contentHash === request.variables.get("expectedContentHash"), "Expected MySQL MD5");
});
%}

### 10. Historical NULL content_hash must be recalculated and persisted
# Set only the chosen test row content_hash to NULL, delete media:md5:{mediaId}, then submit.
# For a reachable MinIO/local object, verify MySQL and Redis are both backfilled with the returned MD5.
POST {{host}}/media/analyze/{{user1MediaId}}
Authorization: Bearer {{user1Token}}
Content-Type: application/json

{}

### 11. User 2 may submit the same content independently
# Both rows must have the same expectedContentHash. Expected keys:
# analysis:active:{user1Id}:{expectedContentHash}
# analysis:active:{user2Id}:{expectedContentHash}
POST {{host}}/media/analyze/{{user2SameContentMediaId}}
Authorization: Bearer {{user2Token}}
Content-Type: application/json

{}

> {%
client.test("Same content owned by another user is independently accepted", function () {
  client.assert(response.status === 202, "Expected HTTP 202");
  client.assert(response.body.status === "SUBMITTED", "Expected independent SUBMITTED task");
  client.assert(response.body.contentHash === request.variables.get("expectedContentHash"), "Expected shared MD5");
});
%}

### Authenticated media list; userId is taken from UserContext, not query parameters
GET {{host}}/media/list
Authorization: Bearer {{user1Token}}

### Debug endpoint with dev profile: remains outside JWT interception
GET {{host}}/debug/ai?id={{user1MediaId}}&goal=Debug analysis task

### Debug endpoint without dev profile: must return 404
GET {{host}}/debug/ai?id={{user1MediaId}}&goal=Debug analysis task
